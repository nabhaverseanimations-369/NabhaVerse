# API service environment variables (FastAPI + Clerk verification)

# Async database URL.
# Local default can remain sqlite for development, Postgres is recommended for production.
DATABASE_URL=sqlite+aiosqlite:///./nabhaverse.db

# Clerk JWT verification settings for backend token validation.
CLERK_ISSUER=https://REPLACE_ME.clerk.accounts.dev
CLERK_JWKS_URL=https://REPLACE_ME.clerk.accounts.dev/.well-known/jwks.json

# Optional expected audience claim for tokens.
# Leave empty only if your Clerk token strategy does not require aud validation.
CLERK_AUDIENCE=
