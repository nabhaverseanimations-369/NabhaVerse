# Web app environment variables (Next.js + Clerk)

# Clerk public key used by browser-side Clerk components.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Clerk secret key used by server-side Clerk helpers only.
# Never expose this value in client code.
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# App Router sign-in/sign-up route configuration.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# Redirects after successful auth when no explicit redirect is provided.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Backend API base URL used by web API calls.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: required only if webhook handlers are added in the web app.
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_REPLACE_ME
